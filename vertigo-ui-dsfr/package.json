{
  "name": "vertigo-dsfr",
  "version": "4.4.0",
  "private": false,
  "type": "module",
  "scripts": {
    "dev": "vite --port 3001",
    "build": "vite build",
    "build-lib": "vite build && cp dist/*.* ../vertigo-ui/src/main/resources/io/vertigo/ui/static/3rdParty/dsfr/",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage --reporter=verbose --coverage.reporter=text --coverage.reporter=html --coverage.reporter=lcov --coverage.reporter=clover"
  },
  "dependencies": {
    "@gouvfr/dsfr": "^1.14.4",
    "@gouvminint/vue-dsfr": "^8.17.0",
    "@iconify-json/ri": "^1.2.3",
    "@trevoreyre/autocomplete": "^3.0.3",
    "@trevoreyre/autocomplete-vue": "^3.0.3",
    "date-fns": "^4.1.2",
    "vue": "^3.5.39"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.10",
    "@vue/test-utils": "^2.4.11",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vite-plugin-externals": "^0.6.2",
    "vitest": "^4.1.10"
  }
}
